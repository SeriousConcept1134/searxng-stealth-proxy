# =============================================================================
# SearXNG Stealth Proxy — Environment Configuration
# Copy this file to .env and fill in the values for your setup.
# =============================================================================

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

# The name of the external Docker/Podman network shared with your SearXNG stack.
# Find it with: docker network ls / podman network ls
# Compose typically prefixes with your folder name (e.g. searxng-docker_searxng-net)
EXTERNAL_NETWORK=searxng-net

# Proxy URL for the sxng-proxy container to route browser traffic through.
# Leave empty for a direct connection (Path A).
# Set to your WARP sidecar for Path B/C (e.g. socks5://searxng-warp:1080).
PROXY_URL=

# Proxy URL accessible from the HOST machine, used by the warmup script.
# Required if using WARP so the warmup browser routes through the same IP.
# Example: socks5://127.0.0.1:1080
HOST_PROXY_URL=

# -----------------------------------------------------------------------------
# Startup Behaviour
# -----------------------------------------------------------------------------

# Seconds to wait after container startup before accepting search requests.
# Useful after a CAPTCHA-triggered re-warm to let the fresh cookie session
# age before automated queries hit it. Set to 0 for normal operation.
# Recommended value after a re-warm: 600 (10 minutes).
STARTUP_IDLE_SECONDS=0

# Search mode: controls how the proxy fetches Google results.
#   direct     — navigates directly to the Google search URL (default, faster)
#   humanized  — simulates organic search via the Google homepage
SEARCH_MODE=direct

# -----------------------------------------------------------------------------
# Warmup Script (host-side only)
# -----------------------------------------------------------------------------

# Override the browser binary used by the warmup script.
# Leave unset to let the script auto-detect installed Chromium browsers.
# Example: /usr/bin/brave-browser
BROWSER_PATH=
