EXTERNAL_NETWORK=searxng-net

# The proxy URL from the perspective of the sxng-proxy CONTAINER
# For 'warp' profile, this is usually 'socks5://searxng-warp:1080' or 'socks5://searxng-warp:9091'
PROXY_URL=socks5://searxng-warp:1080

# The proxy URL from the perspective of your HOST MACHINE (used by manage.py)
# This MUST point to your local host IP/port that routes through Warp
HOST_PROXY_URL=socks5://127.0.0.1:1080
